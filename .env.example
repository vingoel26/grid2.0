# ── Gridlock 2.0 — environment template. Copy to .env and adjust. ──

# Backend
DATABASE_URL=postgresql+asyncpg://gridlock:gridlock@localhost:5432/gridlock
REDIS_URL=redis://localhost:6379
ML_API_KEY=gridlock-ml-key-change-me
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# MinIO (S3-compatible evidence storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=gridlock
MINIO_SECRET_KEY=gridlock123
MINIO_BUCKET=evidence
MINIO_SECURE=false

# ML service
BACKEND_URL=http://localhost:8000
EVIDENCE_DIR=evidence
DEVICE=auto
# Optional Gemini pre-review
GEMINI_API_KEY=
ENABLE_GEMINI_REVIEW=false

# Frontend (set in frontend/.env.local for local dev)
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_WS_URL=ws://localhost:8000
